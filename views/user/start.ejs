<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>NYRAH – Cute Kidswear</title>
    <!-- Cute Premium Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@300;400;500;600;700&family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/user/start.css" />
</head>
<body>

<main class="premium-wrapper">
    <!-- Floating cute decorations -->
    <div class="floating-heart f-1">💖</div>
    <div class="floating-star f-2">✨</div>
    <div class="floating-heart f-3">💗</div>

    <!-- Minimalist Navbar -->
    <nav class="premium-navbar">
        <div class="nav-left">
            <ul class="nav-menu">
                <% if (user) { %> 
                    <li><a href="/home" class="nav-link">Home</a></li>
                    <li><a href="/categories" class="nav-link">Categories</a></li>
                    <li><a href="/AllProducts" class="nav-link">Collections</a></li>
                <% } else { %> 
                    <li><a href="/about" class="nav-link">About Us</a></li>
                    <li><a href="/contact" class="nav-link">Contact</a></li>
                    <li><a href="#" class="nav-link">Collections</a></li>
                <% } %>
            </ul>
        </div>
        
        <a href="/" class="brand-logo">NYRAH</a>

        <div class="nav-actions">
            <% if (user) { %>
                <a href="/profile" class="nav-link">Account</a>
            <% } else { %>
                <a href="/signin" class="nav-link">Log In</a>
                <a href="/signup" class="auth-btn">Sign Up</a>
            <% } %>
        </div>
    </nav>

    <!-- Hero Section -->
    <div class="hero-container">
        <div class="hero-content">
            <span class="hero-subtitle">Premium Kids Fashion</span>
            <h1 class="hero-title">Cute looks<br>for <em>little ones</em>.</h1>
            <p class="hero-description">Discover the most adorable, premium quality clothing designed to let your little ones shine bright every single day.</p>
            <div class="hero-buttons">
                <a href="/home" class="btn-primary">Explore Collection</a>
            </div>
        </div>

        <div class="hero-image-box">
             <div class="image-frame-cute">
                 <img src="/images/cuty.jpg" alt="NYRAH Kids Fashion" class="hero-image-full" />
             </div>
        </div>
    </div>
</main>

</body>
</html>
