<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= product.productName %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/user/product.css">
  <link rel="stylesheet" href="/user/productdetail.css">
</head>
<body>
<%- include('../../views/partials/user/header') %>

<div class="container py-5 position-relative">
  <!-- Playful Background Blobs -->
  <div class="position-absolute cute-blob bg-primary opacity-25" style="top: -50px; right: -50px; width: 300px; height: 300px; z-index: -1;"></div>
  
  <div class="row gx-5 bg-white p-4 p-md-5 rounded-5 shadow-sm" style="border: 2px dashed var(--color-primary-dark);">
    <!-- LEFT: Images -->
    <div class="col-md-6 position-relative">
      <% if(product.productOffer > 0){ %>
        <div class="offer-badge"><%= product.productOffer %>% OFF</div>
      <% } %>

      <img id="mainImage" src="/uploads/productImages/<%= product.productImage[0] %>" class="main-img mb-3">

      <div class="row g-3">
        <% product.productImage.forEach(img => { %>
          <div class="col-3">
            <img src="/uploads/productImages/<%= img %>" class="thumb-img" onclick="document.getElementById('mainImage').src=this.src">
          </div>
        <% }) %>
      </div>
    </div>

    <!-- RIGHT: Product Info -->
    <div class="col-md-6 d-flex flex-column justify-content-center">
      <h2 class="fw-bold mb-3" style="font-family: 'Fredoka', sans-serif; color: var(--color-text-dark);"><%= product.productName %></h2>

      <% 
        const variants = product.variants || [];
        const totalStock = variants.length > 0 ? variants.reduce((sum,v)=>sum+(v.stock||0),0) : product.quantity || 0;
        const productHasStock = totalStock > 0;
        const defaultPrice = variants[0]?.price || product.salesPrice || product.regularPrice || 0;
      %>

      <!-- Price & Ratings -->
      <p class="fw-bold fs-3 text-premium mb-4"> ₹<span id="price"><%= defaultPrice %></span></p>
     

      <!-- Variants -->
      <% if(variants.length>0){ %>
        <div class="mb-3">
          <strong>Color:</strong>
          <div id="colorOptions">
            <% variants.forEach((v,i) => { %>
              <button type="button" class="color-btn <%= i===0?'active':'' %>" onclick="selectColor(this,'<%= v.color %>')"><%= v.color %></button>
            <% }) %>
          </div>
        </div>

        <div class="mb-3">
          <strong>Size:</strong>
          <div id="sizeOptions">
            <% variants.forEach((v,i) => { %>
              <button type="button" class="size-btn <%= i===0?'active':'' %>" data-price="<%= v.price %>" onclick="selectSize(this,'<%= v.size %>')"><%= v.size %></button>
            <% }) %>
          </div>
        </div>
      <% } %>

      <!-- Hidden Inputs -->
      <input type="hidden" id="selectedColor" value="<%= variants[0]?.color || '' %>">
      <input type="hidden" id="selectedSize" value="<%= variants[0]?.size || '' %>">

      <!-- Stock & Buttons -->
      <p class="mb-4">
        <% if(productHasStock) { %>
          <span class="badge bg-success bg-opacity-10 text-success px-3 py-2 rounded-pill"><i class="bi bi-check-circle me-1"></i> In Stock</span>
        <% } else { %>
          <span class="badge bg-danger bg-opacity-10 text-danger px-3 py-2 rounded-pill"><i class="bi bi-x-circle me-1"></i> Out of Stock</span>
        <% } %>
      </p>

      <div class="d-flex gap-3 mb-5">
        <button class="btn btn-outline-premium px-4 d-flex align-items-center gap-2" onclick="toggleWishlist(this)" data-id="<%= product._id %>">
          <i class="bi bi-heart"></i> Wishlist
        </button>
        <% if(productHasStock && !product.isBlock){ %>
          <button class="btn btn-premium px-5" id="addToCartBtn"><i class="bi bi-bag me-2"></i>Add to Cart</button>
        <% } else if(product.isBlock){ %>
          <button class="btn btn-danger px-5 rounded-pill">Currently Unavailable</button>
        <% } else { %>
          <button class="btn btn-warning px-5 rounded-pill text-dark" disabled>Out of Stock</button>
        <% } %>
      </div>

      <!-- Description & Reviews -->
     <ul class="nav nav-tabs mb-3" id="productTabs">
  <li class="nav-item">
    <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#descriptionTab">Description</button>
  </li>
  <li class="nav-item">
    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#reviewTab">Reviews</button>
  </li>
</ul>

<div class="tab-content">
  <div class="tab-pane fade show active p-3 border rounded" id="descriptionTab">
    <p class="text-secondary"><%= product.description %></p>
  </div>

  <div class="tab-pane fade p-3 border rounded" id="reviewTab">
    <% if(product.reviews && product.reviews.length>0){ %>
      <% product.reviews.forEach(r => { %>
        <div class="review-item mb-3 p-2 border rounded">
          <div class="d-flex justify-content-between align-items-center mb-1">
            <strong><%= r.userName %></strong>
            <span class="badge bg-warning text-dark"><%= r.rating %>/5</span>
          </div>
          <p class="mb-0 text-secondary"><%= r.comment %></p>
        </div>
      <% }) %>
    <% } else { %>
      <p class="text-muted">No reviews yet</p>
    <% } %>
  </div>
</div>

    </div>
  </div>

 <!-- Related Products -->
<% if(relatedProducts && relatedProducts.length > 0){ %>
  <div class="text-center mt-5 mb-4">
    <h3 class="section-title">You may also like</h3>
  </div>
  <div class="row g-4">
    <% relatedProducts.forEach(p => { %>
      <div class="col-lg-3 col-md-4 col-6 related-product text-center">
        <div class="related-img-wrapper position-relative">
          <a href="/product/<%= p._id %>" class="d-block h-100"> 
            <img src="/uploads/productImages/<%= p.productImage[0] %>" alt="<%= p.productName %>">
          </a>
        </div>
        <h6 class="mb-1 text-truncate" style="font-family: 'Fredoka', sans-serif;"><%= p.productName %></h6>
        <p class="fw-bold text-premium mb-0">₹<%= p.salesPrice || p.regularPrice %></p>
      </div>
    <% }) %>
  </div>
<% } %>

<%- include('../../views/partials/user/footer') %>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
  const priceEl = document.getElementById("price");

  function selectColor(btn, color){
    document.querySelectorAll('.color-btn').forEach(b=>b.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('selectedColor').value = color;
  }

  function selectSize(btn, size){
    document.querySelectorAll('.size-btn').forEach(b=>b.classList.remove('active'));
    btn.classList.add('active');
    priceEl.innerText = btn.dataset.price;
    document.getElementById('selectedSize').value = size;
  }

  document.getElementById("addToCartBtn")?.addEventListener("click",()=>{
    const selectedSize = document.getElementById("selectedSize").value;
    const selectedColor = document.getElementById("selectedColor").value;
    fetch("/add-to-cart",{
      method:"POST",
      headers:{ "Content-Type":"application/json" },
      body: JSON.stringify({ productId: "<%= product._id %>", size:selectedSize, color:selectedColor })
    }).then(r=>r.json()).then(data=>{
      Swal.fire({
        toast: true,
        position: 'top-end',
        icon: data.success ? 'success' : 'error',
        title: data.message,
        showConfirmButton: false,
        timer: 3000
      });
    }).catch(err=>console.error(err));
  });

  function toggleWishlist(btn){
    let icon = btn.querySelector("i");
    if(icon.classList.contains("bi-heart")){
      icon.classList.replace("bi-heart", "bi-heart-fill");
    } else {
      icon.classList.replace("bi-heart-fill", "bi-heart");
    }
    fetch("/wishlist/add/" + btn.dataset.id).catch(err => console.log(err));
  }
</script>
</body>
</html>