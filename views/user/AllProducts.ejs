<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>All Products - NYRAH</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
<!-- Note: header already includes home.css which contains the premium theme variables and utilities -->
<link rel="stylesheet" href="/user/allProduct.css">
</head>

<body>
<%- include('../../views/partials/user/header') %>

<div class="container my-5 position-relative">
  <!-- Decorative element -->
  <i class="bi bi-stars floating-star position-absolute text-warning" style="top: -20px; right: 10%; font-size: 2rem; z-index: 10;"></i>
  <i class="bi bi-heart-fill floating-heart position-absolute text-danger" style="top: 50%; left: -2%; font-size: 1.5rem; z-index: 10;"></i>

  <div class="text-center mb-5">
    <h2 class="section-title mt-2">All Collection</h2>
    <p class="text-muted fs-5">Find the perfect outfit for every adventure.</p>
  </div>

<!-- ================= TOP FILTER BAR ================= -->
<div class="d-flex justify-content-center mb-5">
  <form method="GET" action="/AllProducts" class="d-flex align-items-center gap-2 flex-nowrap">

    <!-- SEARCH -->
    <input type="text" name="search" placeholder="Search products..." class="form-control" value="<%= selected.search || '' %>" style="width: 250px;">

    <!-- CATEGORY -->
    <select name="category" class="form-select" style="width: 180px;">
      <option value="">All Categories</option>
      <% categories.forEach(cat => { %>
        <option value="<%= cat._id %>" <%= selected.category==cat._id?'selected':'' %>><%= cat.name %></option>
      <% }) %>
    </select>

    <!-- BRAND -->
    <select name="brand" class="form-select" style="width: 180px;">
      <option value="">All Brands</option>
      <% brands.forEach(brand => { %>
        <option value="<%= brand._id %>" <%= selected.brand==brand._id?'selected':'' %>><%= brand.brandName %></option>
      <% }) %>
    </select>

    <!-- PRESERVE OTHER FILTERS -->
    <input type="hidden" name="size" value="<%= selected.size || '' %>">
    <input type="hidden" name="color" value="<%= selected.color || '' %>">
    <input type="hidden" name="priceRange" value="<%= selected.priceRange || '' %>">
    <input type="hidden" name="sort" value="<%= selected.sort || '' %>">

    <button class="btn btn-premium px-4">Search</button>
  </form>
</div>
  <div class="row">

    <!-- LEFT FILTER SIDEBAR -->
    <div class="col-lg-3 col-md-4 mb-4">
      <div class="filter-sidebar bg-white p-4 rounded-5 shadow-sm position-relative overflow-hidden" style="border: 2px solid var(--color-primary);">
        <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
          <strong class="fs-5" style="font-family: 'Fredoka', sans-serif;">Filters</strong>
          <a href="/AllProducts" class="text-danger small text-decoration-none fw-medium"><i class="bi bi-x-circle"></i> Clear</a>
        </div>

        <form method="GET" action="/AllProducts">

          <!-- Preserve top form selections -->
          <input type="hidden" name="search" value="<%= selected.search || '' %>">
          <input type="hidden" name="category" value="<%= selected.category || '' %>">
          <input type="hidden" name="brand" value="<%= selected.brand || '' %>">

          <!-- SORT -->
          <div class="mb-3">
            <select name="sort" class="form-select">
              <option value="">Sort By</option>
              <option value="priceLowHigh" <%= selected.sort=='priceLowHigh'?'selected':'' %>>Price Low → High</option>
              <option value="priceHighLow" <%= selected.sort=='priceHighLow'?'selected':'' %>>Price High → Low</option>
              <option value="aToZ" <%= selected.sort=='aToZ'?'selected':'' %>>A → Z</option>
              <option value="zToA" <%= selected.sort=='zToA'?'selected':'' %>>Z → A</option>
              <option value="newest" <%= selected.sort=='newest'?'selected':'' %>>Newest</option>
            </select>
          </div>

          <!-- SIZE -->
          <div class="mb-3">
            <select name="size" class="form-select">
              <option value="">Size</option>
              <% sizes.forEach(size => { %>
                <option value="<%= size %>" <%= selected.size==size?'selected':'' %>><%= size %></option>
              <% }) %>
            </select>
          </div>

          <!-- COLOR -->
          <div class="mb-3">
            <select name="color" class="form-select">
              <option value="">Color</option>
              <% colors.forEach(color => { %>
                <option value="<%= color %>" <%= selected.color==color?'selected':'' %>><%= color %></option>
              <% }) %>
            </select>
          </div>

          <!-- PRICE -->
          <div class="mb-4">
            <label class="form-label text-muted small fw-bold">PRICE RANGE</label>
            <select name="priceRange" class="form-select rounded-pill custom-select shadow-sm">
              <option value="">Any Price</option>
              <option value="0-500" <%= selected.priceRange=='0-500'?'selected':'' %>>₹0 - ₹500</option>
              <option value="500-1000" <%= selected.priceRange=='500-1000'?'selected':'' %>>₹500 - ₹1000</option>
              <option value="1000-2000" <%= selected.priceRange=='1000-2000'?'selected':'' %>>₹1000 - ₹2000</option>
            </select>
          </div>

          <button class="btn btn-premium w-100 rounded-pill py-2 mt-2">Apply Filters</button>

        </form>
      </div>
    </div>

    <!-- PRODUCT GRID -->
    <div class="col-lg-9 col-md-8">
      <div class="row g-4">
        <% if(products.length === 0){ %>
          <div class="col-12 text-center py-5">
            <i class="bi bi-emoji-frown display-1 text-muted mb-3 d-block"></i>
            <h4 class="text-muted" style="font-family: 'Fredoka', sans-serif;">Oops! No products found.</h4>
            <p class="text-muted">Try adjusting your filters or search term.</p>
          </div>
        <% } else { %>
          <% products.forEach(product => { 
            let totalStock = product.variants?.reduce((sum,v)=>sum+(v.stock||0),0) || product.quantity || 0;
            const hasStock = totalStock > 0;
          %>
            <div class="col-xl-4 col-lg-4 col-md-6 col-sm-6 mb-4 product-wrapper">
              <div class="product-card <%= product.isBlock || !hasStock ? 'border-danger opacity-75' : '' %> h-100">
                <div class="image-wrapper">
                  <!-- Wishlist Button -->
                  <button class="wishlist-btn position-absolute top-0 end-0 m-3 border-0 bg-white rounded-circle shadow-sm text-danger d-flex align-items-center justify-content-center" onclick="toggleWishlist(this); event.stopPropagation();" data-id="<%= product._id %>" style="z-index:10; width:40px; height:40px; transition:0.3s;">
                    <i class="bi bi-heart"></i>
                  </button>
                        <% if(product.productOffer > 0){ %>
                       <div class="position-absolute top-0 start-0 m-3 badge bg-premium shadow-sm px-3 py-2 rounded-pill" style="z-index:10; background: var(--color-accent); color: white;">
                          <%= product.productOffer %>% OFF
                       </div>
                       <% } %>
                  <% if(product.isBlock){ %>
                    <div class="badge-unavailable position-absolute top-0 start-0 m-3 z-1">Unavailable</div>
                  <% } else if(!hasStock){ %>
                    <div class="badge-unavailable position-absolute top-0 start-0 m-3 z-1" style="color: #ffc107;">Out Of Stock</div>
                  <% } %>
                      
                  <% if(!product.isBlock && hasStock){ %>
                    <img src="/uploads/productImages/<%= product.productImage?.[0] || 'no-image.jpg' %>" class="img-fluid" onclick="location.href='/product/<%= product._id %>'">
                  <% } else { %>
                    <img src="/uploads/productImages/<%= product.productImage?.[0] || 'no-image.jpg' %>" class="img-fluid">
                  <% } %>
                  
                </div>

                <div class="card-body d-flex flex-column text-center">
                  <h5 class="product-title text-truncate" title="<%= product.productName %>"><%= product.productName %></h5>
                  <div class="d-flex justify-content-center align-items-baseline gap-2 mt-auto">
                    <p class="product-price mb-0">₹<%= product.salesPrice || product.regularPrice %></p>
                    <% if(product.productOffer>0){ %>
                      <p class="text-muted text-decoration-line-through small mb-0">₹<%= product.regularPrice %></p>
                    <% } %>
                  </div>
                  
                </div>
              </div>
            </div>
          <% }) %>
        <% } %>
      </div>

      <!-- PAGINATION -->
      <nav class="mt-4">
        <ul class="pagination justify-content-center">
          <% for(let i=1;i<=totalPages;i++){ %>
            <li class="page-item <%= currentPage==i?'active':'' %>">
              <a class="page-link" href="/AllProducts?<%= Object.keys(selected).map(k=>k+'='+selected[k]).join('&') %>&page=<%= i %>"><%= i %></a>
            </li>
          <% } %>
        </ul>
      </nav>

    </div>
  </div>
</div>

<%- include('../../views/partials/user/footer') %>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<script>
function toggleWishlist(btn){
  btn.classList.toggle("active");
  let icon = btn.querySelector("i");
  if(icon.classList.contains("bi-heart")){
    icon.classList.remove("bi-heart");
    icon.classList.add("bi-heart-fill");
  }else{
    icon.classList.remove("bi-heart-fill");
    icon.classList.add("bi-heart");
  }
  fetch("/wishlist/add/" + btn.dataset.id).catch(err => console.log(err));
}
</script>

</body>
</html>