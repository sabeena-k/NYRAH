<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>All Products - NYRAH</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
<link rel="stylesheet" href="/user/allProduct.css">
</head>

<body>

<%- include('../../views/partials/user/header') %>
<div class="container mt-4">

<!-- TOP DROPDOWNS -->
<div class="d-flex justify-content-center gap-3 mb-4">

<form method="GET" action="/AllProducts" class="d-flex gap-3">


<!-- CATEGORY -->
<select name="category" class="form-select">
<option value="">Category</option>

<% categories.forEach(cat => { %>

<option value="<%= cat._id %>">
<%= cat.name %>
</option>

<% }) %>

</select>

<!-- BRAND -->
<select name="brand" class="form-select">
<option value="">Brand</option>

<% brands.forEach(brand => { %>

<option value="<%= brand._id %>">
<%= brand.brandName %>
</option>

<% }) %>

</select>

<button class="btn btn-danger">Apply</button>

</form>

</div>


<div class="row">

<!-- LEFT FILTER SIDEBAR -->

<div class="col-md-3">

<div class="filter-sidebar p-3">

<div class="d-flex justify-content-between mb-3">
<strong>FILTERS & SORT</strong>
<a href="/AllProducts" class="text-muted small">Clear All</a>
</div>

<form method="GET" action="/AllProducts">

<!-- SORT -->
<div class="mb-3">

<select name="sort" class="form-select">
<option value="">Sort By</option>
<option value="priceLowHigh">Price Low → High</option>
<option value="priceHighLow">Price High → Low</option>
<option value="aToZ">A → Z</option>
<option value="zToA">Z → A</option>
</select>

</div>

<!-- SIZE -->
<select name="size" class="form-select">
<option value="">Size</option>

<% sizes.forEach(size => { %>

<option value="<%= size %>" <%= selected.size==size?'selected':'' %>>
<%= size %>
</option>

<% }) %>

</select>
<br>

<!-- COLOR -->
<select name="color" class="form-select">
<option value="">Color</option>

<% colors.forEach(color => { %>

<option value="<%= color %>" <%= selected.color==color?'selected':'' %>>
<%= color %>
</option>

<% }) %>

</select>
<br>
<!-- PRICE -->
<div class="mb-3">

<select name="priceRange" class="form-select">
<option value="">Price</option>
<option value="0-500">0 - 500</option>
<option value="500-1000">500 - 1000</option>
<option value="1000-2000">1000 - 2000</option>
</select>

</div>

<button class="btn btn-dark w-100">Apply</button>

</form>

</div>

</div>


<!-- PRODUCT GRID -->
  <div class="col-md-9">
     <div class="row g-4"> 
      <% products.forEach(function(product){
         let totalStock = 0;
          if(product.variants && product.variants.length > 0){
             totalStock = product.variants.reduce((sum,v)=>sum+(v.stock||0),0); 
            }else{ totalStock = product.quantity || 0; 
            } 
            let hasStock = totalStock > 0; %>
             <div class="col-md-4 col-sm-6"> 
              <div class="product-card <%= product.isBlock || !hasStock ? 'blocked':'' %>">
                 <div class="img-box"> <% if(product.isBlock){ %>
                   <div class="status-badge bg-danger">Currently Unavailable</div> 
             <% } else if(!hasStock){ %> 
              <div class="status-badge bg-warning">Out Of Stock</div>
                <% } %>
                  <% if(!product.isBlock && hasStock){ %> 
                   <a class="wishlist-btn" data-id="<%= product._id %>" onclick="toggleWishlist(this)">
                        <i class="bi bi-heart"></i>

                     </a> <% } %> 
                     <img src="/uploads/productImages/<%= product.productImage?.[0] || 'no-image.jpg' %>" <% if(!product.isBlock && hasStock){
                  %> onclick="location.href='/product/<%= product._id %>'" <% } %>>
                           </div>
                      <div class="p-3 text-center">
                        <h6><%= product.productName %></h6>
                        
                        <div class="price-box">
                        ₹<%= product.salesPrice || product.regularPrice %>
                        
                        <% if(product.productOffer > 0){ %>
                        <span class="old-price">₹<%= product.regularPrice %></span>
                        <% } %>
                        
                        </div>
                        
                        <% if(product.productOffer > 0){ %>
                        
                        <div class="offer-label">
                        <%= product.productOffer %>% OFF
                        </div>
                        
                        <% } %>
                        
                        </div>

                    </div> 
                   </div>
                        <% }) %> 
            </div>
                </div> 
             </div> 
              </div>


<%- include('../../views/partials/user/footer') %>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>

function toggleWishlist(btn){

btn.classList.toggle("active");

let icon = btn.querySelector("i");

if(icon.classList.contains("bi-heart")){
icon.classList.remove("bi-heart");
icon.classList.add("bi-heart-fill");
}else{
icon.classList.remove("bi-heart-fill");
icon.classList.add("bi-heart");
}

fetch("/wishlist/add/" + btn.dataset.id)
.catch(err => console.log(err));

}

</script>
</body>
</html>