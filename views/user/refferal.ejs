<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Referral Code</title>
   <link rel="stylesheet" href="/public/user/referel.css">
<body>

<div class="container">
    <div class="card">

        <h2>Enter the Referral Code</h2>
        <p class="subtitle">
            Enter your referral code to enjoy extra rewards. When you sign up using a referral code,
            both you and your friend receive a bonus.
        </p>

        <% if (error) { %>
        <p class="error"><%= error %></p>
        <% } %>

        <form action="/referral" method="POST">
            <input type="text" name="referral" placeholder="Enter Referral Code" required>
            <button type="submit">Submit</button>
        </form>

    </div>
</div>

</body>
</html>
