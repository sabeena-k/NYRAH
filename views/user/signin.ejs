<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@400;500;600;700&family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/user/home.css" />
<link rel="stylesheet" href="/user/signin.css" />
<title>NYRAH Login</title>
</head>
<body>
 
<div class="outer-box shadow-lg">
    <div class="login-container">
    

        
        <div class="left-box">
             <div id="successMsg" class="success-message"></div>
            <h2 class="logo">NYRAH</h2>

            <div class="center-box">
               <button id="googleLoginBtn" class="google-btn shadow-sm">
                <img src="https://img.icons8.com/color/48/google-logo.png" />
                <span>Continue with Google</span>
              </button>
              <p id="errorMsg" style="color:var(--color-accent); display:none;"></p>
            </div>

            <p class="or"><span>or</span></p>

            <form id="loginForm" method="POST" action="/signin">
              <input class="input focus-ring-none" type="email" name="email" placeholder="Email Address">
              <input class="input focus-ring-none" type="password" name="password" placeholder="Password">
              
              <div id="error2" class="error-message"></div>

              <% if (locals.message && message.length > 0) { %>
                  <div class="custom-alert">
                      <%= message %>
                  </div>
              <% } %>

              <button type="submit" class="login-btn btn-premium shadow-sm">Sign In</button><br>

              <a href="/forgot-password" class="forgot-link">Forgot Password?</a>

              <div class="bottom-link mt-4">
                  <span>New to NYRAH? </span> 
                  <a href="/signup" class="text-premium fw-bold" style="text-decoration:none;">Create an account</a>
              </div>
            </form>

        </div>
        <div class="right-box">
            <img src="images/pink.webp" alt="login image">
        </div>

    </div>
</div>

</body>
<script>

if (performance.getEntriesByType("navigation")[0].type === "back_forward") {
  location.reload(true);
}

history.pushState(null, null, location.href);
window.onpopstate = function () {
  history.go(1);
};

const params = new URLSearchParams(window.location.search);

if (params.get("msg") === "account_created") {
  const box = document.getElementById("successMsg");
  box.textContent = "Account created successfully!";

  document.addEventListener("click", () => {
    box.style.display = "none";
  }, { once: true });
}

// 🔥 MOVE THIS OUTSIDE
window.addEventListener("message", (event) => {

  if (event.data === "google-login-success") {
    window.location.reload();
  }

  if (event.data === "google-login-blocked") {
    const errorBox = document.getElementById("errorMsg");
    errorBox.textContent = "User is blocked by admin";
    errorBox.style.display = "block";
  }

});

const loginBtn = document.getElementById("googleLoginBtn");

loginBtn.addEventListener("click", () => {
  const width = 500;
  const height = 600;
  const left = (screen.width - width) / 2;
  const top = (screen.height - height) / 2;

  window.open(
    "/auth/google",
    "Google Login",
    `width=${width},height=${height},top=${top},left=${left}`
  );
});
</script>