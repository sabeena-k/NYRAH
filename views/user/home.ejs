<%- include("../partials/user/header") %>

<!-- HERO SLIDER -->
<div id="heroSlider" class="carousel slide carousel-fade mb-5 shadow-sm" data-bs-ride="carousel" data-bs-interval="5000">
  <div class="carousel-inner rounded-bottom-4 overflow-hidden">

    <div class="carousel-item active">
      <img src="/images/ima.webp" class="d-block w-100" alt="Kids Fashion" style="border-radius: 0 0 50px 50px;">
      <div class="hero-text text-center w-100 start-0 pe-0">
        <i class="bi bi-stars floating-star position-absolute" style="top:-20px; left:20%;"></i>
        <i class="bi bi-heart-fill floating-heart position-absolute" style="top:40px; right:15%;"></i>
        <h1 class="display-3 fw-bold text-white mb-2" style="font-family: 'Fredoka';">Happiness looks good</h1>
        <h1 class="display-3 fw-light text-white mb-4" style="font-family: 'Fredoka';">on every child. ✨</h1>
        <p class="fs-5 text-white-50 mb-4 mx-auto w-75">Discover the new premium collection for your little ones, designed with comfort and love.</p>
        <a href="/AllProducts" class="btn btn-premium btn-lg rounded-pill px-5 border-white border-2">Explore Collection</a>
      </div>
    </div>

    <div class="carousel-item">
      <img src="/images/select.jpg" class="d-block w-100" alt="Beautiful Dress" style="border-radius: 0 0 50px 50px;">
      <div class="hero-text text-center w-100 start-0 pe-0">
        <i class="bi bi-heart-fill floating-heart position-absolute" style="top:-10px; left:25%;"></i>
        <i class="bi bi-stars floating-star position-absolute" style="top:50px; right:20%;"></i>
        <h1 class="display-3 fw-bold text-white mb-2" style="font-family: 'Fredoka';">Dress for Joy</h1>
        <h1 class="display-3 fw-light text-white mb-4" style="font-family: 'Fredoka';">every single day. 🎀</h1>
        <p class="fs-5 text-white-50 mb-4 mx-auto w-75">Style meets playtime in our latest arrivals. Perfect fits for every adventure.</p>
        <a href="/newArrivals" class="btn btn-premium btn-lg rounded-pill px-5 border-white border-2">View New Arrivals</a>
      </div>
    </div>

    <div class="carousel-item">
      <img src="/images/sho.webp" class="d-block w-100" alt="Trendy Shoes">
      <div class="hero-text">
        <h1 class="display-3 fw-bold text-white mb-2">Tiny Steps</h1>
        <h1 class="display-3 fw-light text-white mb-4">to big dreams.</h1>
        <p class="fs-5 text-white-50 mb-4 me-5 pe-5">Comfortable style to support their journey everywhere they go.</p>
        <a href="/newArrivals" class="btn btn-premium btn-lg rounded-pill px-5">Latest styles</a>
      </div>
    </div>

  </div>

  <button class="carousel-control-prev" type="button" data-bs-target="#heroSlider" data-bs-slide="prev">
    <span class="carousel-control-prev-icon rounded-circle bg-dark bg-opacity-50 p-3" aria-hidden="true"></span>
    <span class="visually-hidden">Previous</span>
  </button>

  <button class="carousel-control-next" type="button" data-bs-target="#heroSlider" data-bs-slide="next">
    <span class="carousel-control-next-icon rounded-circle bg-dark bg-opacity-50 p-3" aria-hidden="true"></span>
    <span class="visually-hidden">Next</span>
  </button>
</div>

<!-- CATEGORIES SECTION -->
<div class="container my-5 py-4">
  <div class="text-center mb-5">
    <h2 class="section-title mt-2">Categories</h2>
  </div>

  <div class="row g-4 justify-content-center">
    <% if(categories && categories.length > 0){ %>
      <% categories.forEach((cat, index) => { %>
        <div class="col-6 col-md-4 col-lg-3 category-wrapper">
          <a href="/category/<%= cat._id %>" class="text-decoration-none">
            <div class="old-photo-card">
              <div class="old-photo-img-wrapper">
                <img src="/uploads/categoryImages/<%= cat.image %>" alt="<%= cat.name %>">
              </div>
              <h6 class="old-photo-title text-uppercase tracking-wider"><%= cat.name %></h6>
            </div>
          </a>
        </div>
      <% }) %>
    <% } else { %>
      <div class="text-center">
        <p class="text-muted fs-5">No Categories Found at the moment. Check back later!</p>
      </div>
    <% } %>
  </div>
</div>

<!-- NEW COLLECTIONS -->
<div class="container my-5 py-5 bg-white rounded-5 shadow-sm px-4 px-md-5 position-relative overflow-hidden" style="border: 4px dashed var(--color-primary);">
  <!-- Decorative background elements -->
  <div class="position-absolute top-0 end-0 bg-primary opacity-25 cute-blob" style="width: 200px; height: 200px; transform: translate(30%, -30%);"></div>
  <div class="position-absolute bottom-0 start-0 badge-unavailable cute-blob" style="width: 300px; height: 300px; transform: translate(-30%, 30%); background: var(--color-primary-dark); opacity: 0.2"></div>

  <div class="text-center mb-5 position-relative z-1">
    <h2 class="section-title mt-2">New Collections</h2>
  </div>

  <div class="row g-4 position-relative z-1">
    <% if(newCollections && newCollections.length > 0) { %>
      <% newCollections.forEach((product, index) => { %>
        <div class="col-sm-6 col-md-4 col-lg-3 mb-4 product-wrapper">
          <div class="product-card <%= product.isBlock ? 'border-danger' : '' %>">
            <div class="image-wrapper">
              <% if(product.isBlock){ %>
                <div class="position-absolute top-0 start-0 w-100 h-100 d-flex justify-content-center align-items-center bg-white bg-opacity-50 z-2">
                  <span class="badge-unavailable">Currently Unavailable</span>
                </div>
              <% } %>
              <img src="<%= product.productImage[0] ? `/uploads/productImages/${product.productImage[0]}` : '/images/no-image.jpg' %>" alt="<%= product.productName %>">
            </div>
            
            <div class="card-body">
              <h5 class="product-title text-truncate" title="<%= product.productName %>"><%= product.productName %></h5>
              <div class="d-flex justify-content-center align-items-baseline gap-2 mt-auto">
                <% if(product.salesPrice) { %>
                  <p class="product-price mb-0">₹ <%= product.salesPrice %></p>
                  <% if(product.regularPrice > product.salesPrice) { %>
                    <p class="text-muted text-decoration-line-through small mb-0">₹ <%= product.regularPrice %></p>
                  <% } %>
                <% } else { %>
                  <p class="product-price mb-0">₹ <%= product.regularPrice %></p>
                <% } %>
              </div>
              
              <div class="mt-4">
                <% if(!product.isBlock){ %>
                  <a href="/product/<%= product._id %>" class="btn-card-action w-100">View Details</a>
                <% } else { %>
                  <button class="btn btn-secondary w-100 rounded-pill" disabled>Unavailable</button>
                <% } %>
              </div>
            </div>
          </div>
        </div>
      <% }) %>
    <% } else { %>
      <div class="col-12 text-center py-5">
        <i class="bi bi-box2 text-muted display-1 mb-3"></i>
        <h4 class="text-muted">No New Collections Found</h4>
        <p class="text-muted">We're working on gathering new styles. Stay tuned!</p>
      </div>
    <% } %>
  </div>
</div>

<!-- PROMO BANNER -->
<div class="container my-5 py-4 position-relative">
  <i class="bi bi-stars floating-star position-absolute" style="top:10px; left:10%; z-index:5;"></i>
  <i class="bi bi-heart-fill floating-heart position-absolute" style="bottom:20px; right:5%; z-index:5;"></i>
  <div class="row align-items-center bg-white rounded-5 overflow-hidden shadow-sm" style="border: 3px solid var(--color-primary-dark);">
    <div class="col-md-6 p-5 p-md-5 text-center text-md-start">
      <span class="badge bg-premium mb-3 px-3 py-2 rounded-pill shadow-sm" style="background: var(--color-accent); color: white;">💖 Special Offer</span>
      <h2 class="display-5 fw-bold text-dark mb-4" style="font-family: 'Fredoka';">Style Up Their Wardrobe ✨</h2>
      <p class="text-muted fs-5 mb-4">Discover exclusive prints, ultra-soft fabrics, and tailored fits designed explicitly for growing kids.</p>
      <a href="/AllProducts" class="btn btn-premium btn-lg rounded-pill px-5">Shop The Look</a>
    </div>
    <div class="col-md-6 p-0 h-100">
      <img src="/images/top.webp" class="img-fluid w-100 h-100" style="object-fit: cover; min-height: 400px;" alt="Banner Promotional">
    </div>
  </div>
</div>

<%- include("../partials/user/footer") %>