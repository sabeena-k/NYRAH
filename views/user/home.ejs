<%- include("../partials/user/header") %>


<!-- HERO SLIDER -->
<div id="heroSlider" class="carousel slide" data-bs-ride="carousel">
  <div class="carousel-inner">

    <div class="carousel-item active">
      <img src="/images/ima.webp" class="d-block w-100" style="height:680px;object-fit:cover;object-position:top;">
      <div class="hero-text text-center">
        <h1>"Happiness looks good</h1>
        <h1>on every child."</h1>
      </div>
    </div>

    <div class="carousel-item">
      <img src="/images/select.jpg" class="d-block w-100" style="height:680px;object-fit:cover;object-position:top;">
      <div class="hero-text text-center">
        <h1>"Happiness looks good</h1>
        <h1>on every child."</h1>
      </div>
    </div>

    <div class="carousel-item">
      <img src="/images/sho.webp" class="d-block w-100" style="height:680px;object-fit:cover;object-position:top;">
      <div class="hero-text text-center">
        <h1>"Happiness looks good</h1>
        <h1>on every child."</h1>
      </div>
    </div>

  </div>

  <button class="carousel-control-prev" type="button" data-bs-target="#heroSlider" data-bs-slide="prev">
    <span class="carousel-control-prev-icon"></span>
  </button>

  <button class="carousel-control-next" type="button" data-bs-target="#heroSlider" data-bs-slide="next">
    <span class="carousel-control-next-icon"></span>
  </button>
</div>


<!-- CATEGORIES SECTION -->
<div class="container mt-5">

  <h3 class="text-center mb-4 fw-bold">EXPLORE</h3>

  <div class="row g-4">

    <% if(categories && categories.length > 0){ %>

      <% categories.forEach(cat => { %>

        <div class="col-6 col-md-3">

         <a href="/category/<%= cat._id %>" class="text-decoration-none">
            <div class="category-card text-center">

              <div class="category-img-wrapper">
                <img 
                  src="/uploads/categoryImages/<%= cat.image %>" 
                  class="img-fluid"
                  alt="<%= cat.name %>"
                >
              </div>

              <h6 class="mt-3 fw-bold text-dark">
                <%= cat.name %>
              </h6>

            </div>

          </a>

        </div>

      <% }) %>

    <% } else { %>

      <div class="text-center">
        <p>No Categories Found</p>
      </div>

    <% } %>

  </div>

</div>



<!-- NEW COLLECTIONS -->
<div class="container mt-5">

<h3 class="fw-bold text-center mb-4">NEW COLLECTIONS</h3>

<% if(newCollections.length > 0) { %>

<div class="row">

<% newCollections.forEach(product => { %>

<div class="col-md-3 mb-4">

<div class="card h-100 <%= product.isBlock ? 'border-danger' : '' %>">

<div class="image-wrapper position-relative">

<% if(product.isBlock){ %>
<span class="badge bg-danger position-absolute m-2">
Currently Unavailable
</span>
<% } %>

<img 
src="<%= product.productImage[0] ? `/uploads/productImages/${product.productImage[0]}` : '/images/no-image.jpg' %>" 
class="card-img-top"
style="height:250px;object-fit:cover;"
>

</div>

<div class="card-body text-center">

<h6><%= product.productName %></h6>

<p class="fw-bold">
₹ <%= product.salesPrice || product.regularPrice %>
</p>

<% if(!product.isBlock){ %>

<a href="/product/<%= product._id %>" class="btn btn-dark btn-sm">
View Details
</a>

<% } else { %>

<button class="btn btn-secondary btn-sm" disabled>
Unavailable
</button>

<% } %>

</div>

</div>

</div>

<% }) %>

</div>

<% } else { %>

<p class="text-center text-muted">No New Collections Found</p>

<% } %>

</div>


<!-- BANNER -->
<div class="middle my-5 text-center">

<img src="/images/top.webp" class="img-fluid" alt="Banner">

</div>


<%- include("../partials/user/footer") %>