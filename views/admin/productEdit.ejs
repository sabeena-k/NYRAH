<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Edit Product - NYRAH</title>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
<link rel="stylesheet" href="/admin/dashboard.css">
<link rel="stylesheet" href="/admin/prodectEdit.css">

<style>
body { background-color: #ffe6e6; }
.form-box { background: #fff0f0; padding: 20px; border-radius: 10px; }
button.cancel { background: white; border: 1px solid #333; }
button.add { background: #f44c3a; color: white; }
.thumb-img { width: 80px; margin-right: 5px; border-radius: 5px; }
.image-preview img { width: 100px; height: 100px; margin-right: 5px; border-radius: 5px; }
.thumb-img:hover { opacity: 0.7; }
.delete-btn { position: absolute; top: 0; right: 0; background: rgb(235, 229, 229); color: worrgb(9, 9, 9); border: none; border-radius: 50%; width: 20px; height: 20px; cursor: pointer; }
</style>
</head>

<body>
<div class="container-fluid d-flex">
  <%- include('../../views/partials/admin/side') %>

 <main class="main w-100">
    <h3 class="mb-3">Edit Product</h3>

    <div class="form-box">
      <form class="product-form" method="POST" action="/admin/products/edit/<%= product._id %>" enctype="multipart/form-data">

        <!-- Existing Images -->
        <div class="mb-3">
          <label>Current Images</label><br>
          <% product.productImage.forEach((img) => { %>
            <div style="display:inline-block; position:relative; margin:5px;">
              <img src="/uploads/productImages/<%= img %>" class="thumb-img">
              <button type="button" class="delete-btn" onclick="removeImage('<%= img %>')">&times;</button>
            </div>
          <% }) %>
          <input type="hidden" name="existingImages" id="existingImages" value="<%= product.productImage.join(',') %>">
        </div>

        <!-- Add New Images -->
        <div class="mb-3">
          <label>Add New Images</label>
          <input type="file" id="imageInput" name="images" accept="image/*" multiple class="form-control">
          <div id="preview" class="image-preview mt-2"></div>
        </div>

        <div class="mb-3">
          <label>Product Name</label>
          <input type="text" name="name" class="form-control" value="<%= product.productName %>" required>
        </div>

        <div class="mb-3">
          <label>Description</label>
          <textarea name="description" class="form-control"><%= product.description %></textarea>
        </div>

        <div class="row mb-3">
          <div class="col">
            <label>Category</label>
            <select name="category" class="form-select">
              <% categories.forEach(c => { %>
                <option value="<%= c._id %>" <%= product.category?._id.toString()===c._id.toString() ? "selected":"" %>><%= c.name %></option>
              <% }) %>
            </select>
          </div>
          <div class="col">
            <label>Brand</label>
            <select name="brand" class="form-select">
              <% brands.forEach(b => { %>
                <option value="<%= b._id %>" <%= product.brand.toString()===b._id.toString()?"selected":"" %>><%= b.brandName %></option>
              <% }) %>
            </select>
          </div>
        </div>

        <div class="row mt-3">
          <div class="col-md-6">
            <label>Size</label>
            <select name="size" id="sizeSelect" class="form-control">
              <% sizes.forEach(s => { %>
                <option value="<%= s %>" <%= product.size && product.size.some(sz => sz.size === s) ? "selected" : "" %> >
                  <%= s %>
                </option>
              <% }) %>
            </select>
          </div>
          <div class="col">
            <label>Color</label>
            <select name="color" class="form-select">
              <% colors.forEach(c => { %>
                <option value="<%= c %>" <%= product.color===c ? "selected":"" %>><%= c %></option>
              <% }) %>
            </select>
          </div>
        </div>

        <div class="row mb-3 mt-3">
          <div class="col">
            <label>Price</label>
            <input type="number" name="price" id="priceInput" class="form-control" value="<%= product.regularPrice %>" required>
          </div>
          <div class="col">
            <label>Offer Price</label>
            <input type="number" name="offerPrice" id="offerInput" class="form-control" value="<%= product.salesPrice %>">
          </div>
        </div>

        <div class="mb-3">
          <label>Quantity</label>
          <input type="number" name="quantity" class="form-control" value="<%= product.quantity %>">
        </div>

        <div class="mb-3">
          <button type="button" class="btn cancel" onclick="window.location.href='/admin/products'">Cancel</button>
          <button type="submit" class="btn add">Update Product</button>
        </div>

      </form>
    </div>
  </main>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
const priceInput = document.getElementById("priceInput");
const offerInput = document.getElementById("offerInput");
const existingImagesInput = document.getElementById("existingImages");
let existingImages = existingImagesInput.value ? existingImagesInput.value.split(",") : [];

// Delete existing image
function removeImage(imgName){
  existingImages = existingImages.filter(i => i !== imgName);
  existingImagesInput.value = existingImages.join(",");
  const imgDiv = event.target.parentNode;
  imgDiv.remove();
}

// New image preview
const imageInput = document.getElementById("imageInput");
const preview = document.getElementById("preview");

imageInput.addEventListener("change", e => {
  preview.innerHTML = "";
  Array.from(e.target.files).forEach(file => {
    const reader = new FileReader();
    reader.onload = () => {
      const img = document.createElement("img");
      img.src = reader.result;
      img.style.width = "100px";
      img.style.height = "100px";
      img.style.marginRight = "5px";
      img.style.borderRadius = "5px";
      preview.appendChild(img);
    };
    reader.readAsDataURL(file);
  });
});

// Form validation
document.querySelector(".product-form").addEventListener("submit", e=>{
  const newImagesLength = document.getElementById("imageInput").files.length;
  const existingImagesVal = document.getElementById("existingImages").value;
  const existingImagesLength = existingImagesVal ? existingImagesVal.split(",").filter(x => x.trim()).length : 0;
  
  if (existingImagesLength + newImagesLength < 3) {
    e.preventDefault();
    Swal.fire("Error", "Please ensure the product has at least 3 images.", "error");
    return;
  }

  if(Number(offerInput.value) > Number(priceInput.value)){
    e.preventDefault();
    Swal.fire("Error","Offer price must not be greater than regular price","error");
  }
});
</script>

</body>
</html>