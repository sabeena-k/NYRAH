<!DOCTYPE html>
<html>
<head>
<title>NYRAH Admin – Brands</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<link rel="stylesheet" href="/admin/brand.css">
</head>
<body>

<div class="container">

<%- include('../../views/partials/admin/side') %>

<main class="main">

<%- include('../../views/partials/admin/header') %>

<div class="page-content">

<div class="header-bar">
<h2>Brands</h2>
<button onclick="openAddBrand()">+ Add Brand</button>
</div>

<table>
<thead>
<tr>
<th>Brand</th>
<th>Logo</th>
<th>Status</th>
<th>Actions</th>
</tr>
</thead>

<tbody>
<% brands.forEach(b => { %>
<tr>

<td><%= b.brandName %></td>

<td>
<% if(b.brandImage){ %>
<img src="/uploads/productImages/<%= b.brandImage %>" class="thumb-img">
<% } else { %>
No image
<% } %>
</td>

<td><%= b.isBlocked ? "Blocked" : "Active" %></td>

<td>
<button onclick="editBrand('<%= b._id %>','<%= b.brandName %>')">Edit</button>
<button onclick="deleteBrand('<%= b._id %>')">Delete</button>
</td>

</tr>
<% }) %>
</tbody>

</table>

</div>

<%- include('../../views/partials/admin/footer') %>

</main>
</div>



<script>
async function openAddBrand() {
    const { value: formValues } = await Swal.fire({
        title: "Add Brand",
        html:
          `<input id="addBrandName" class="swal2-input" placeholder="Brand Name">
           <input type="file" id="addBrandImage"name="brandImage" class="swal2-file" accept="image/*">
           <img id="addImagePreview" style="display:none; width:120px; margin-top:10px;">`,
        showCancelButton: true,
        confirmButtonText: "Create",
        didOpen: () => {
          const fileInput = document.getElementById("addBrandImage");
          const preview = document.getElementById("addImagePreview");
          fileInput.addEventListener("change", () => {
            const file = fileInput.files[0];
            if(file) {
              preview.src = URL.createObjectURL(file);
              preview.style.display = "block";
            }
          });
        },
        preConfirm: () => {
          const brandName = document.getElementById("addBrandName").value;
          const brandImage = document.getElementById("addBrandImage").files[0];
          if(!brandName) Swal.showValidationMessage("Brand name is required");
          return { brandName, brandImage };
        }
    });

    if(formValues) {
        const formData = new FormData();
        formData.append("brandName", formValues.brandName);
        if(formValues.brandImage) formData.append("brandImage", formValues.brandImage);

        const res = await fetch("/admin/brand/add", { method: "POST", body: formData });
        const data = await res.json();

        Swal.fire("Success", data.msg, "success").then(() => location.reload());
    }
}
async function editBrand(id, name) {
  Swal.fire({
    title: "Edit Brand",
    html: `
      <input id="editBrandName" class="swal2-input" value="${name}">
      <input type="file" id="editBrandImage" name="brandImage" class="swal2-file" accept="image/*">
      <img id="imagePreview" style="display:none; width:120px; margin-top:10px; border-radius:6px;">
    `,
    didOpen: () => {
      const fileInput = document.getElementById("editBrandImage");
      const preview = document.getElementById("imagePreview");

      fileInput.addEventListener("change", () => {
        const file = fileInput.files[0];
        if (file) {
          preview.src = URL.createObjectURL(file);
          preview.style.display = "block";
        }
      });
    },
    confirmButtonText: "Save",
    showCancelButton: true,
    preConfirm: () => {
      const brandName = document.getElementById("editBrandName").value;
      const brandImage = document.getElementById("editBrandImage").files[0];
      if (!brandName) Swal.showValidationMessage("Brand name is required");
      return { brandName, brandImage };
    }
  }).then(async (result) => {
    if (result.isConfirmed) {
      const formData = new FormData();
      formData.append("id", id);
      formData.append("brandName", result.value.brandName);
      if (result.value.brandImage) formData.append("brandImage", result.value.brandImage);

      const res = await fetch("/admin/brand/edit", { method: "POST", body: formData });
      const data = await res.json();
      Swal.fire("Updated!", data.msg, "success").then(() => location.reload());
    }
  });
}

async function deleteBrand(id) {
  const result = await Swal.fire({
    title: 'Delete the Brand?',
    text: "You won't be able to revert this!",
    icon: 'warning',
    showCancelButton: true,
    confirmButtonColor: '#d81b60',
    cancelButtonColor: '#555',
    confirmButtonText: 'Yes, delete it!'
  });

  if (result.isConfirmed) {
    const res = await fetch("/admin/brand/delete", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ id })
    });

    const data = await res.json();

    Swal.fire({
      title: "Deleted!",
      text: data.msg || "Brand deleted successfully",
      icon: "success",
      confirmButtonColor: "#d81b60"
    }).then(() => location.reload());
  }
}
</script>


</body>
</html>