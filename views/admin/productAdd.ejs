<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Add New Product - NYRAH</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/cropperjs@1.5.13/dist/cropper.min.css" rel="stylesheet"/>
<link rel="stylesheet" href="/admin/dashboard.css">
<link rel="stylesheet" href="/admin/poductAdd.css">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body>
    <div> <%- include('../../views/partials/admin/side') %></div>
 
<div class="page-container">


  <div class="content">
    <h2>Add New Product</h2>

    <form class="product-form" method="POST" action="/admin/products/add" enctype="multipart/form-data">

      <div class="row">
<div class="input-box col-md-6">
<label>Product Name</label>
<small class="error-msg"></small>
<input type="text" name="name">
</div>

<div class="input-box col-md-6">
<label>Product ID</label>
<input type="text" value="SKU-12345" readonly>
</div>
</div>

<div class="row">
<div class="input-box col-md-6">
<label>Price</label>
<small class="error-msg"></small>
<input type="number" name="price">
</div>

<div class="input-box col-md-6">
<label>Offer Price</label>
<small class="error-msg"></small>
<input type="number" name="offerPrice">
</div>
</div>

<div class="input-box">
<label>Description</label>
<small class="error-msg"></small>
<textarea name="description"></textarea>
</div>

<div class="row">
<div class="input-box col-md-6">
<label>Category</label>
<small class="error-msg"></small>
<select name="category">
<option value="">Select Category</option>
<option value="1">Category 1</option>
</select>
</div>

<div class="input-box col-md-6">
<label>Brand</label>
<small class="error-msg"></small>
<select name="brand">
<option value="">Select Brand</option>
<option value="1">Brand 1</option>
</select>
</div>
</div>

<div class="row">
<div class="input-box col-md-6">
<label>Size</label>
<small class="error-msg"></small>
<select name="size">
<option value="">Select Size</option>
<option>S</option>
<option>M</option>
</select>
</div>

<div class="input-box col-md-3">
<label>Quantity</label>
<small class="error-msg"></small>
<input type="number" name="quantity">
</div>

<div class="input-box col-md-3">
<label>Color</label>
<small class="error-msg"></small>
<input type="text" name="color">
</div>
</div>

<!-- Image -->
<div>
<button type="button" id="chooseBtn">Choose Images</button>
<input type="file" id="imageInput" multiple style="display:none">
<div id="preview"></div>
</div>

<button 
  type="submit" 
  class="btn btn-success px-4 py-2 fw-bold rounded-3 mt-5">
  Add Product
</button>
<button 
  type="button" 
  class="btn btn-outline-dark px-4 py-2 rounded-3 mt-5"
  onclick="window.location.href='/admin/products'">
  Cancel
</button>
<div id="cropModal" class="modal">
  <div class="modal-content">
    <img id="cropImage">
    <br>
    <button id="cropBtn">Crop & Save</button>
    <button id="closeModal">Cancel</button>
  </div>
</div>
</form>
</div>
</div>

<script src="https://cdn.jsdelivr.net/npm/cropperjs@1.5.13/dist/cropper.min.js"></script>
<script>
let cropper;
let croppedFiles = [];

const fileInput = document.getElementById("imageInput");
const preview = document.getElementById("preview");
const cropModal = document.getElementById("cropModal");
const cropImage = document.getElementById("cropImage");
const cropBtn = document.getElementById("cropBtn");
const closeModal = document.getElementById("closeModal");

document.getElementById("chooseBtn").onclick = () => fileInput.click();

// 👉 Select image → open crop modal
fileInput.addEventListener("change", (e) => {
    const file = e.target.files[0]; // only one at a time

    if (!file) return;

    const reader = new FileReader();

    reader.onload = function () {
        cropImage.src = reader.result;
        cropModal.style.display = "flex";

        if (cropper) cropper.destroy();

        cropper = new Cropper(cropImage, {
            aspectRatio: 1,
            viewMode: 1
        });
    };

    reader.readAsDataURL(file);
});

// 👉 Crop & save
cropBtn.addEventListener("click", () => {
    if (!cropper) return;

    const canvas = cropper.getCroppedCanvas({
        width: 500,
        height: 500
    });

    canvas.toBlob((blob) => {
        const file = new File([blob], Date.now() + ".jpg", {
            type: "image/jpeg"
        });

        croppedFiles.push(file);

        // update input files
        const dataTransfer = new DataTransfer();
        croppedFiles.forEach(f => dataTransfer.items.add(f));
        fileInput.files = dataTransfer.files;

        // preview
        const img = document.createElement("img");
        img.src = URL.createObjectURL(file);
        preview.appendChild(img);

        cropModal.style.display = "none";
        cropper.destroy();
    });
});

// 👉 close modal
closeModal.addEventListener("click", () => {
    cropModal.style.display = "none";
    if (cropper) cropper.destroy();
});
document.querySelector(".product-form").addEventListener("submit", function (e) {

let isValid = true;

const fields = [
"name","price","description","category",
"brand","size","quantity","color"
];

// clear errors
document.querySelectorAll(".error-msg").forEach(el => el.textContent = "");
document.querySelectorAll("input,textarea,select").forEach(el => el.classList.remove("error"));

fields.forEach(name => {
const input = this[name];
const value = input.value.trim();
const errorEl = input.parentElement.querySelector(".error-msg");

if (!value) {
errorEl.textContent = "All fields are required";
input.classList.add("error");
isValid = false;
}
});

// offer price check
const price = Number(this.price.value);
const offer = Number(this.offerPrice.value);

if (offer && offer >= price) {
const errorEl = this.offerPrice.parentElement.querySelector(".error-msg");
errorEl.textContent = "Offer price must be less than price";
this.offerPrice.classList.add("error");
isValid = false;
}

// image check
if (croppedFiles.length < 3){
 Swal.fire({
        icon: "warning",
        title: "Images Required",
        text: "Please upload at least 3 product images",
        confirmButtonColor: "#d14d4d"
    });
isValid = false;
}

if (!isValid) e.preventDefault();

});
</script>

</body>
</html>