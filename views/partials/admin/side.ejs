<style>
  @import url('https://fonts.googleapis.com/css2?family=Fredoka:wght@300;400;500;600;700&display=swap');

  :root {
    --color-primary: #ffe1e8;
    --color-primary-dark: #ffb6c1;
    --color-accent: #e53e5d;
    --color-accent-hover: #c92f4c;
    --color-text-dark: #1f2937;
    --color-bg-light: #fff0f3;
  }

  body {
    font-family: 'Fredoka', sans-serif !important;
    background-color: var(--color-bg-light) !important;
    color: var(--color-text-dark) !important;
  }

  .sidebar {
    background: #fff !important;
    box-shadow: 2px 0 15px rgba(255, 182, 193, 0.4) !important;
  }

  .brand {
    font-family: 'Fredoka', cursive !important;
    color: var(--color-accent) !important;
    letter-spacing: 1px;
    font-size: 28px !important;
    text-shadow: 0 2px 4px rgba(229, 62, 93, 0.2);
  }

  .menu li a {
    border-radius: 12px !important;
    font-weight: 500 !important;
  }
  
  .menu li a:hover, .menu li a.active {
    background: var(--color-primary) !important;
    color: var(--color-accent) !important;
    transform: translateX(5px);
  }

  /* Cards and Buttons */
  button, .btn {
    font-family: 'Fredoka', sans-serif !important;
    border-radius: 20px !important;
    font-weight: 500 !important;
    transition: 0.3s ease !important;
  }
  
  /* Bubbly Tables and Boxes */
  .box, table, .modal-content, .card {
    border-radius: 20px !important;
    box-shadow: 0 8px 20px rgba(255, 182, 193, 0.2) !important;
    border: 2px solid var(--color-primary);
  }

  table {
    border-collapse: separate;
    border-spacing: 0;
    overflow: hidden;
  }
  
  th {
    background-color: var(--color-primary) !important;
    color: var(--color-accent) !important;
    font-weight: 600 !important;
  }

  /* Inputs */
  input, select, textarea {
    font-family: 'Fredoka', sans-serif !important;
    border-radius: 12px !important;
    border: 1px solid var(--color-primary-dark) !important;
  }

  input:focus, select:focus, textarea:focus {
    outline: none !important;
    border-color: var(--color-accent) !important;
    box-shadow: 0 0 8px rgba(229, 62, 93, 0.3) !important;
  }
</style>

<aside class="sidebar">
    <h1 class="brand">NYRAH</h1>
    <ul class="menu">

        <li><a href="/admin"><i class="bi bi-speedometer2"></i> Dashboard</a></li>
        <li><a href="/admin/order"><i class="bi bi-bag"></i> Order</a></li>
        <li><a href="/admin/products"><i class="bi bi-box-seam"></i> Products</a></li>
        <li><a href="/admin/brand"><i class="bi bi-shield-check"></i> Brand</a></li>
        <li><a href="/admin/sales-report"><i class="bi bi-graph-up"></i> Sales report</a></li>
        <li><a href="/admin/customers"><i class="bi bi-people"></i> Customers</a></li>
        <li><a href="/admin/category"><i class="bi bi-tags"></i> Category</a></li>
        <li><a href="/admin/coupon"><i class="bi bi-percent"></i> Coupon</a></li>
        <li><a href="/admin/refund"><i class="bi bi-arrow-repeat"></i> Refund</a></li>
        <li><a href="/admin/banners"><i class="bi bi-image"></i> Banners</a></li>
        <li><a href="/admin/logout"><i class="bi bi-box-arrow-right"></i> Sign Out</a></li>

    </ul>
</aside>
<script>
const links = document.querySelectorAll(".menu li a");
const currentPath = window.location.pathname;

links.forEach(link => {
    const linkPath = link.getAttribute("href");

    if (linkPath === "/admin" && currentPath === "/admin") {
        link.classList.add("active");
    }

    if (linkPath !== "/admin" && currentPath.startsWith(linkPath)) {
        link.classList.add("active");
    }
});
</script>