<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>NYRAH</title>
  
  <!-- Modern Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@400;500;600;700&family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  
  <!-- Icons & Bootstrap -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/user/home.css">
</head>

<body>
<header class="sticky-top glass-nav shadow-sm">
<nav class="navbar navbar-expand-lg navbar-light py-3">
  <div class="container">

    <a class="navbar-brand fw-bold text-premium" href="/" style="font-size: 2.2rem; font-family: 'Fredoka', cursive; letter-spacing: 2px;">NYRAH</a>

    <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
      <span class="bi bi-list fs-1 text-premium"></span>
    </button>

    <div class="collapse navbar-collapse" id="navMenu">

      <!-- Menu -->
      <ul class="navbar-nav mx-auto mb-2 mb-lg-0 gap-4">
        <li class="nav-item"><a href="/home" class="nav-link custom-link">Home</a></li>
        <li class="nav-item"><a href="/newArrivals" class="nav-link custom-link">New Arrivals</a></li>
        <li class="nav-item"><a href="/AllProducts" class="nav-link custom-link">All Products</a></li>
      </ul>

      <div class="d-flex align-items-center gap-3">

        <% if (!user) { %>

          <a href="/signin" class="btn btn-premium">Sign In</a>
          <a href="/signup" class="btn btn-outline-premium">Sign Up</a>

        <% } else { %>

        <!-- Search -->
        <div class="search-container position-relative">
          <div class="input-group search-group">
            <span class="input-group-text bg-transparent border-end-0"><i class="bi bi-search text-muted"></i></span>
            <input type="text" id="searchInput" placeholder="Search lovely styles..." class="form-control border-start-0 rounded-end-pill pl-0 focus-ring-none shadow-none">
          </div>
          <div id="searchResults" class="position-absolute bg-white rounded-4 shadow-lg border-0 w-100 mt-2"></div>
        </div>

        <!-- Wishlist -->
        <a href="/wishlist" class="nav-icon-link">
          <i class="bi bi-heart"></i>
        </a>

        <!-- Cart -->
        <a href="/cart" class="nav-icon-link">
          <i class="bi bi-bag"></i>
        </a>

        <!-- Profile Dropdown -->
        <div class="dropdown">
          <div class="profile-circle glass-circle dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
            <%= user?.name?.charAt(0)?.toUpperCase() || "U" %>
          </div>

          <ul class="dropdown-menu dropdown-menu-end shadow-premium border-0 rounded-4 mt-2 p-2">
            <li class="px-3 py-2 text-muted small user-welcome">
              Hello, <strong class="text-dark"><%= user.name %></strong>
            </li>
            <li><hr class="dropdown-divider border-light"></li>
            <li>
              <a class="dropdown-item rounded-3 py-2" href="/profile"><i class="bi bi-person me-2"></i> My Profile</a>
            </li>
            <li>
              <a class="dropdown-item rounded-3 py-2" href="/orders"><i class="bi bi-box-seam me-2"></i> My Orders</a>
            </li>
            <li>
              <a class="dropdown-item rounded-3 py-2" href="/wishlist"><i class="bi bi-heart me-2"></i> Wishlist</a>
            </li>
            <li><hr class="dropdown-divider border-light"></li>
            <li>
              <a href="/logout" class="dropdown-item rounded-3 py-2 text-danger"><i class="bi bi-box-arrow-right me-2"></i> Logout</a>
            </li>
          </ul>
        </div>
        <% } %>

      </div>

    </div>
  </div>
</nav>
</header>
<script>
const searchInput = document.getElementById("searchInput");
const searchResults = document.getElementById("searchResults");

function debounce(fn, delay) {
  let timeoutId;
  return function (...args) {
    clearTimeout(timeoutId);
    timeoutId = setTimeout(() => fn.apply(this, args), delay);
  };
}

async function handleSearch() {
  const query = searchInput.value.trim();
  if (!query) {
    searchResults.innerHTML = "";
    searchResults.style.display = "none";
    searchResults.classList.remove('show-results');
    return;
  }

  const res = await fetch(`/search-products?q=${encodeURIComponent(query)}`);
  const data = await res.json();

  searchResults.innerHTML = data.map(p => `
    <div class="search-item d-flex align-items-center gap-2 p-3 border-bottom">
      <a href="/product/${p._id}" 
         class="text-dark text-decoration-none fw-medium w-100 d-block">
         ${p.productName}
      </a>
    </div>
  `).join("");

  searchResults.style.display = "block";
  setTimeout(() => searchResults.classList.add('show-results'), 10);
}

searchInput.addEventListener("input", debounce(handleSearch, 500));
</script>
